Build/*
!Build/.gitkeep
Assets/Converted/*
!Assets/Converted/.gitkeep
*.lst
*.sym
*.spg
*.bin
*.tap
*.trd
*.scl
*.hob
*.tmp
*.bak
*.zip

# Тяжёлое/нестандартное — вне истории кода (сырьё, снимки, диагностика, мусор)
Assets/Original/
releases/
Diagnostics/
*.png
/111
OpenHMM2/

# Python bytecode
__pycache__/
*.pyc

# Старые локальные опорные снимки v001-v019 не добавляем задним числом.
/Pre-releases/v0[01][0-9]-*/

# Текущая опорная версия публикуется в формате проекта.
!/Pre-releases/
!/Pre-releases/v020-2026-07-16-adventure-ui-battle-ai-reference/
