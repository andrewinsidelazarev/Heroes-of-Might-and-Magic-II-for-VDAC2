 341+ 0020              ;       * VM_640_480_76Hz
 342+ 0020              ;       * VM_800_600_60Hz
 343+ 0020              ;       * VM_800_600_69Hz
 344+ 0020              ;       * VM_800_600_85Hz
 345+ 0020              ;       * VM_1024_768_59Hz
 346+ 0020              ;       * VM_1024_768_67Hz
 347+ 0020              ;       * VM_1024_768_76Hz
 348+ 0020              ; Out :
