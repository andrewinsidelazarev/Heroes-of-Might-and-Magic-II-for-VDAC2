 394  53B4             >                else
 394  53B4 ~           >                LD (MemoryPages + 2), A
 394  53B4 ~           >                LD BC, PAGE2
 394  53B4 ~           >                OUT (C), A
 394  53B4             >                endif
 395  53B4 B7                           OR   A
 396  53B5 C9                           RET
