 245  52A1 3E A0                        LD   A, HMM2_LOADER_PAGE
 246  52A3                              SetPage3_A
 246  52A3             >                ifdef MAPPING_REGISTERS
 246  52A3 32 13 04    >                LD (FMADDR_REGS + HIGH PAGE3), A
 246  52A6             >                else
 246  52A6 ~           >                LD (MemoryPages + 3), A
 246  52A6 ~           >                LD BC, PAGE3
 246  52A6 ~           >                OUT (C), A
 246  52A6             >                endif
 247  52A6 C9                           RET
