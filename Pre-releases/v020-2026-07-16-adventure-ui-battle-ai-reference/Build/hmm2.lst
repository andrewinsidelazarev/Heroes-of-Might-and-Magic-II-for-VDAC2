 255  52B2 18 0E                        JR   Loader_StreamCommon
 256  52B4              ; Loader_StreamToRamG — стрим открытого файла (с текущей позиции) в RAM_G[0] чанками
 257  52B4              ; по 32 сектора. Вход: BC = число секторов. ДОЛЖНА быть в slot1: цикл делает
 258  52B4              ; SetPage2_A(buffer) под FT.WriteMem, и код в slot2 исчез бы во время ремапа.
 259  52B4              ; Состояние тоже в slot1. КРИТИЧНО (Zuma): весь чанк сначала с SD, потом весь DMA.
 260  52B4              Loader_StreamToRamG:
 261  52B4 ED 43 2A 53                  LD   (LdStreamRemain), BC
 262  52B8 21 00 00                     LD   HL, 0
 263  52BB 22 2C 53                     LD   (LdStreamRamgLo), HL
 264  52BE AF                           XOR  A
 265  52BF 32 2E 53                     LD   (LdStreamRamgHi), A
 266  52C2              Loader_StreamCommon:
 267  52C2 ED 4B 2A 53  .loop:          LD   BC, (LdStreamRemain)
 268  52C6 78                           LD   A, B
 269  52C7 B1                           OR   C
 270  52C8 20 06                        JR   NZ, .chunk                  ; ещё есть данные
 271  52CA                              ; Стрим окончен: за секунды без Input_Scan PS/2 FIFO переполнился —
 272  52CA                              ; break-коды потеряны, латчи клавиш ЗАЛИПАЮТ (ловилось: AltGr=1 →
 273  52CA                              ; попап «по hover»). Дренаж мусора + сброс латчей.
 274  52CA CD 0C 56                     CALL Input_DiscardPS2Fifo
 275  52CD C3 D7 55                     JP   Input_ClearState
 276  52D0              .chunk:
 277  52D0 78                           LD   A, B                        ; chunk = min(32, remain) → B
 278  52D1 B7                           OR   A
 279  52D2 20 08                        JR   NZ, .full
 280  52D4 79                           LD   A, C
 281  52D5 FE 20                        CP   32
 282  52D7 30 03                        JR   NC, .full
 283  52D9 41                           LD   B, C
 284  52DA 18 02                        JR   .read
 285  52DC 06 20        .full:          LD   B, 32
 286  52DE C5           .read:          PUSH BC
 287  52DF 0E A1                        LD   C, RAWPAK_BUF_PAGE
 288  52E1 21 00 00                     LD   HL, 0
 289  52E4 CD 6A 52                     CALL Loader_ReadSectors          ; чанк с SD в buffer-page (восстанавливает slot2)
 290  52E7 C1                           POP  BC
 291  52E8 3E A1                        LD   A, RAWPAK_BUF_PAGE
 292  52EA                              SetPage2_A                       ; buffer-page в slot2 для FT.WriteMem
 292  52EA             >                ifdef MAPPING_REGISTERS
 292  52EA 32 12 04    >                LD (FMADDR_REGS + HIGH PAGE2), A
 292  52ED             >                else
 292  52ED ~           >                LD (MemoryPages + 2), A
 292  52ED ~           >                LD BC, PAGE2
 292  52ED ~           >                OUT (C), A
 292  52ED             >                endif
 293  52ED C5                           PUSH BC
 294  52EE 60                           LD   H, B
 295  52EF 2E 00                        LD   L, 0
 296  52F1 29                           ADD  HL, HL                      ; HL = B*512 (байт чанка)
 297  52F2 44                           LD   B, H
 298  52F3 4D                           LD   C, L
 299  52F4 21 00 80                     LD   HL, #8000
 300  52F7 3A 2E 53                     LD   A, (LdStreamRamgHi)
 301  52FA ED 5B 2C 53                  LD   DE, (LdStreamRamgLo)
 302  52FE CD 23 7C                     CALL FT.WriteMem
 303  5301 3E 06                        LD   A, CorePage + 1
 304  5303                              SetPage2_A                       ; вернуть Core
 304  5303             >                ifdef MAPPING_REGISTERS
