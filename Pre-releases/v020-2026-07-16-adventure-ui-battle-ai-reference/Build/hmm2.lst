   1+ ABB1                              ifndef _HMM2_MUSIC_
   2+ ABB1                              define _HMM2_MUSIC_
   3+ ABB1              ; ============================================================================
   4+ ABB1              ; Музыка HMM2 через MIDI-синтезатор SAM2695 (General MIDI) на MIDI-порту AY.
   5+ ABB1              ; Оригинальная музыка — XMI в HEROES2.AGG → SMF (xmi2mid.py) → компактный покадровый
   6+ ABB1              ; поток (music_pack.py): вся tempo-математика свёрнута в Python, здесь — простой плеер.
   7+ ABB1              ;
   8+ ABB1              ; MIDI-выход: AY port A (регистр 14), бит 2 — стандартная схема ZX Spectrum 128 /
   9+ ABB1              ; ZX Evolution (как в zx-midiplayer UzixLS). Bit-bang 31250 бод: start(0)+8data(LSB)+stop(1).
  10+ ABB1              ; Значение порта: бит2=1 → #FE, бит2=0 → #FA (остальные биты idle high).
  11+ ABB1              ;
  12+ ABB1              ; Формат потока (music_pack.py):
  13+ ABB1              ;   #F8 nn      — ждать nn кадров;
  14+ ABB1              ;   #FF         — конец (зациклить);
  15+ ABB1              ;   #80..#EF …  — MIDI-событие: status + данные (Cx/Dx → 1 байт, иначе 2). Без running status.
  16+ ABB1              ; ============================================================================
  17+ ABB1
  18+ ABB1              ; Тайминг bit-bang ТОЧНО по zx-midiplayer uart_putc для 14МГц (448 такт/бит = 31250 бод):
  19+ ABB1              ; .B = внутренний счётчик 26, .C = задержка после стоп-бита 24. Симметричные ветки 0/1 (обе
  20+ ABB1              ; jr .nextbit), переходы JP NZ (10T), 2 nop — как в эталоне. Прерывания в HMM2 ВЫКЛЮЧЕНЫ
  21+ ABB1              ; (platform_tsconf: DI + INT mask 0), поэтому di/ei оригинала не нужны и опущены.
  22+ ABB1              MIDI_BIT_DELAY  EQU 26                    ; .B (14МГц)
  23+ ABB1              MIDI_STOP_DELAY EQU 24                    ; .C (14МГц, межбайтовый зазор после стоп-бита)
  24+ ABB1
  25+ ABB1              ; Music_InitPort: КРИТИЧНО перед любой отправкой — настроить AY port A на ВЫХОД
  26+ ABB1              ; (рег 7, бит 6 = 1), иначе запись в рег 14 не выходит на физ. пин MIDI → тишина
  27+ ABB1              ; (zx-midiplayer uart_prepare). Затем выставить линию в idle-high (stop-уровень).
  28+ ABB1              Music_InitPort:
  29+ ABB1 01 FD FF                     LD   BC, #FFFD
  30+ ABB4 3E 07                        LD   A, #07              ; AY регистр 7 (mixer / направление портов)
  31+ ABB6 ED 79                        OUT  (C), A
  32+ ABB8 06 BF                        LD   B, #BF              ; BC=#BFFD
  33+ ABBA 3E FC                        LD   A, #FC              ; бит6=1 → port A на ВЫХОД (MIDI-линия)
  34+ ABBC ED 79                        OUT  (C), A
  35+ ABBE 06 FF                        LD   B, #FF              ; BC=#FFFD
  36+ ABC0 3E 0E                        LD   A, #0E              ; регистр 14 (port A data)
  37+ ABC2 ED 79                        OUT  (C), A
  38+ ABC4 06 BF                        LD   B, #BF
  39+ ABC6 3E FE                        LD   A, #FE              ; бит2=1 → линия idle high (между байтами)
  40+ ABC8 ED 79                        OUT  (C), A
  41+ ABCA C9                           RET
  42+ ABCB
  43+ ABCB              ; MIDI_PutByte: A=байт → SAM2695 через AY (reg14, bit2), 31250 бод. Портит A,BC,DE; HL цел.
  44+ ABCB              MIDI_PutByte:
  45+ ABCB 5F                           LD   E, A
  46+ ABCC 01 FD FF                     LD   BC, #FFFD
  47+ ABCF 3E 0E                        LD   A, #0E
  48+ ABD1 ED 79                        OUT  (C), A              ; выбрать AY-регистр 14 (I/O port A)
  49+ ABD3 06 BF                        LD   B, #BF              ; BC=#BFFD — запись данных порта A
  50+ ABD5 16 0A                        LD   D, 1 + 8 + 1        ; START + 8 DATA + STOP
  51+ ABD7 37                           SCF                      ; STOP-бит в CF — выдвинется через RR E
  52+ ABD8 18 0B                        JR   .put0               ; START-бит (0)
  53+ ABDA CB 1B        .loop:          RR   E                   ; (8) следующий бит (LSB вперёд) в CF
  54+ ABDC D2 E5 AB                     JP   NC, .put0           ; (10)
  55+ ABDF 3E FE        .put1:          LD   A, #FE              ; (7) бит2=1
  56+ ABE1 ED 79                        OUT  (C), A              ; (11)
  57+ ABE3 18 06                        JR   .nextbit            ; (12)
  58+ ABE5 3E FA        .put0:          LD   A, #FA              ; (7) бит2=0
  59+ ABE7 ED 79                        OUT  (C), A              ; (11)
  60+ ABE9 18 00                        JR   .nextbit            ; (12) симметрично put1 — равный тайминг 0/1
  61+ ABEB 3E 00        .nextbit:       LD   A, 0                ; (7) .A — тайминг-填充 (на 14МГц остаётся ld a,0)
  62+ ABED 3E 1A                        LD   A, MIDI_BIT_DELAY   ; (7) .B = 26
  63+ ABEF 3D           .dlb:           DEC  A                   ; (4×26)
  64+ ABF0 C2 EF AB                     JP   NZ, .dlb            ; (10×26)
  65+ ABF3 00                           NOP                      ; (4)
  66+ ABF4 00                           NOP                      ; (4)
  67+ ABF5 15                           DEC  D                   ; (4)
  68+ ABF6 C2 DA AB                     JP   NZ, .loop           ; (10) → 448 такт/бит = 31250 бод
  69+ ABF9 1E 18                        LD   E, MIDI_STOP_DELAY  ; .C = 24 — зазор после стоп-бита
  70+ ABFB 1D           .dlc:           DEC  E
  71+ ABFC 20 FD                        JR   NZ, .dlc
  72+ ABFE C9                           RET
  73+ ABFF
  74+ ABFF              ; Music_GMReset: GM System On (SysEx F0 7E 7F 09 01 F7) — перевести SAM2695 в General MIDI.
  75+ ABFF              Music_GMReset:
  76+ ABFF 21 10 AC                     LD   HL, MidiGMOn
  77+ AC02 06 06                        LD   B, MidiGMOn_SIZE
  78+ AC04 7E           .l:             LD   A, (HL)
  79+ AC05 E5                           PUSH HL
  80+ AC06 C5                           PUSH BC
  81+ AC07 CD CB AB                     CALL MIDI_PutByte
  82+ AC0A C1                           POP  BC
  83+ AC0B E1                           POP  HL
  84+ AC0C 23                           INC  HL
  85+ AC0D 10 F5                        DJNZ .l
  86+ AC0F C9                           RET
  87+ AC10 F0 7E 7F 09  MidiGMOn:       DEFB #F0, #7E, #7F, #09, #01, #F7
  87+ AC14 01 F7
  88+ AC16              MidiGMOn_SIZE   EQU $ - MidiGMOn
  89+ AC16
  90+ AC16              ; Music_Start: HL = адрес покадрового потока. Запоминает начало (для зацикливания) и активирует.
  91+ AC16              Music_Start:
  92+ AC16 22 6D 42                     LD   (MusicPtr), HL
  93+ AC19 22 6F 42                     LD   (MusicStart), HL
  94+ AC1C AF                           XOR  A
  95+ AC1D 32 6C 42                     LD   (MusicWait), A
  96+ AC20 3C                           INC  A
  97+ AC21 32 6B 42                     LD   (MusicActive), A
  98+ AC24 C9                           RET
  99+ AC25
 100+ AC25              ; Music_Stop: гасит все ноты (CC123=0 на 16 каналах) и снимает активность.
 101+ AC25              Music_Stop:
 102+ AC25 AF                           XOR  A
 103+ AC26 32 6B 42                     LD   (MusicActive), A
 104+ AC29 06 00                        LD   B, 0                ; канал 0..15
 105+ AC2B C5           .ch:            PUSH BC
 106+ AC2C 3E B0                        LD   A, #B0
 107+ AC2E B0                           OR   B                   ; status = Control Change | channel
 108+ AC2F CD CB AB                     CALL MIDI_PutByte
 109+ AC32 3E 7B                        LD   A, #7B              ; CC 123 = All Notes Off
 110+ AC34 CD CB AB                     CALL MIDI_PutByte
 111+ AC37 AF                           XOR  A
 112+ AC38 CD CB AB                     CALL MIDI_PutByte
