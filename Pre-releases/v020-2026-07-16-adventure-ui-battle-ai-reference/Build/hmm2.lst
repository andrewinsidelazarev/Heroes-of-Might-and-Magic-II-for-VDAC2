  65+ 554D                              ; --- 4. Текущий видеорежим: 1024×768 ---------------------
  66+ 554D                              ; Режим 1024×768 даёт больше строкового бюджета для SPI/DMA.
  67+ 554D                              ; Игровой viewport остаётся логическим 640×480 и выводится
  68+ 554D                              ; через nearest upscale 8/5; механику в 1024×768 не пересчитывать.
  69+ 554D                              ; Макрос пишет HCYCLE, HOFFSET, HSYNC0/1, HSIZE, VCYCLE,
  70+ 554D                              ; VOFFSET, VSYNC0/1, VSIZE и REG_PCLK = F_MUL.
  71+ 554D                              FT_RESOLUTION VM_1024_768_59Hz, ResolutionWidthPtr
  71+ 554D             >                if     VM_1024_768_59Hz == VM_640_480_57Hz
  71+ 554D ~           >                LD HL, 640
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 480
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
  71+ 554D             >                elseif Resolution? == VM_640_480_74Hz
  71+ 554D ~           >                LD HL, 640
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 480
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
  71+ 554D             >                elseif Resolution? == VM_640_480_76Hz
  71+ 554D ~           >                LD HL, 640
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 480
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
  71+ 554D             >                elseif Resolution? == VM_800_600_60Hz
  71+ 554D ~           >                LD HL, 800
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 600
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
  71+ 554D             >                elseif Resolution? == VM_800_600_69Hz
  71+ 554D ~           >                LD HL, 800
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 600
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
  71+ 554D             >                elseif Resolution? == VM_800_600_85Hz
  71+ 554D ~           >                LD HL, 800
  71+ 554D ~           >                LD (ResolutionRef? + 0), HL
  71+ 554D ~           >                LD HL, 600
  71+ 554D ~           >                LD (ResolutionRef? + 2), HL
