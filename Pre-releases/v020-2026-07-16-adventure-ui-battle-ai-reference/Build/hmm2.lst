 252+ 5767 B7                           OR   A
 253+ 5768 C0                           RET  NZ                                    ; AltGr держится → «ПКМ нажата»
 254+ 5769 3E 02                        LD   A, Input.Mouse.SVK_RBUTTON
 255+ 576B CD 5B 51                     CALL Input.Mouse.KeyState
 256+ 576E FE 02                        CP   Input.Mouse.SVK_RBUTTON
 257+ 5770 C9                           RET
