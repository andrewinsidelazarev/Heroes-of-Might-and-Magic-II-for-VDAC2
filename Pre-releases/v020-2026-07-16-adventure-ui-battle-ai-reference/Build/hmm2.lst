3588+ FE35              ; Клик по колодцу: EXIT → закрыть; секция построенного жилища → штатный найм. Портит всё.
3589+ FE35              Well_Click:
3590+ FE35 CD 22 FE                     CALL Well_ExitHit
3591+ FE38 28 05                        JR   Z, .notexit
3592+ FE3A AF                           XOR  A
3593+ FE3B 32 E8 E4                     LD   (TownWellOpen), A             ; закрыть (construct рестримится лениво)
3594+ FE3E C9                           RET
3595+ FE3F CD 54 57     .notexit:       CALL Input_MouseY                  ; секция: ряд = (y−1)/150 (0..2), кол = x≥314
3596+ FE42 11 01 00                     LD   DE, 1
3597+ FE45 B7                           OR   A
3598+ FE46 ED 52                        SBC  HL, DE
3599+ FE48 D8                           RET  C
3600+ FE49 06 00                        LD   B, 0                          ; ряд
3601+ FE4B 11 96 00     .rw:            LD   DE, 150
3602+ FE4E B7                           OR   A
3603+ FE4F ED 52                        SBC  HL, DE
3604+ FE51 38 03                        JR   C, .rok
3605+ FE53 04                           INC  B
3606+ FE54 18 F5                        JR   .rw
3607+ FE56 78           .rok:           LD   A, B
3608+ FE57 FE 03                        CP   3
3609+ FE59 D0                           RET  NC                            ; ниже секций
3610+ FE5A C5                           PUSH BC
3611+ FE5B CD 50 57                     CALL Input_MouseX
3612+ FE5E 11 3A 01                     LD   DE, 314
3613+ FE61 B7                           OR   A
3614+ FE62 ED 52                        SBC  HL, DE
3615+ FE64 C1                           POP  BC
3616+ FE65 78                           LD   A, B                          ; i = ряд + (кол?3:0)
3617+ FE66 38 02                        JR   C, .col0
3618+ FE68 C6 03                        ADD  A, 3
3619+ FE6A F5           .col0:          PUSH AF
3620+ FE6B CD 7F FD                     CALL Well_DwellBuilt
3621+ FE6E 28 22                        JR   Z, .nb
3622+ FE70 F1                           POP  AF
3623+ FE71 F5                           PUSH AF                            ; доступно > 0?
3624+ FE72 87                           ADD  A, A
3625+ FE73 6F                           LD   L, A
3626+ FE74 26 00                        LD   H, 0
3627+ FE76 11 04 E5                     LD   DE, DwellAvail
3628+ FE79 19                           ADD  HL, DE
3629+ FE7A 7E                           LD   A, (HL)
3630+ FE7B 23                           INC  HL
3631+ FE7C B6                           OR   (HL)
3632+ FE7D 28 13                        JR   Z, .nb
3633+ FE7F F1                           POP  AF                            ; открыть ШТАТНЫЙ найм для жилища A
3634+ FE80 32 E3 E4                     LD   (TownRecruitIdx), A
3635+ FE83 AF                           XOR  A
