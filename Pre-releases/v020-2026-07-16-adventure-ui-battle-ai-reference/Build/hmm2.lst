   3+ C000              ; ============================================================================
   4+ C000              ; Экран главного меню — зеркалит game_mainmenu.cpp (drawMainMenuScreen + MainMenu loop).
   5+ C000              ; Оригинал: фон ICN::HEROES[0] (640×480) + кнопки ICN::BTNSHNGL (New Game / Load /
   6+ C000              ; High Scores / Credits / Quit) + анимированный фонарь у двери (ICN::SHNGANIM).
   7+ C000              ;
   8+ C000              ; ПО ОРИГИНАЛУ воспроизводятся:
   9+ C000              ;   - hover кнопок: при наведении кадр base+1 (в оригинале ++frame), увод → base;
  10+ C000              ;   - pressed: при зажатой ЛКМ над кнопкой кадр base+2;
  11+ C000              ;   - анимация фонаря: ICN::SHNGANIM (1+frame%39), ПРОРЕЖЕНА под RAM_G (аппаратная
  12+ C000              ;     оговорка: 39 кадров 136×180 ≈ 932 КБ не влезают в 1 МБ RAM_G вместе с фоном).
  13+ C000              ; Quit рисуется со всеми состояниями (по оригиналу), но КЛИК неактивен — на VDAC2/
  14+ C000              ; TS-Config нет программного сброса платы (аппаратное ограничение).
  15+ C000              ;
  16+ C000              ; Ассеты (фон-куски + кнопки rel/hover/pressed + фонарь + палитры) извлекает
  17+ C000              ; menu_pack.py → generated_menu.inc:
  18+ C000              ;   MenuBg_DL — статический DL фона; MenuSpritesProlog/End_DL — обрамление спрайтов;
  19+ C000              ;   MenuLanternBase_DL + MenuLanternFrameTab; MenuBtnFrameTab (3 указателя/кнопку);
  20+ C000              ;   MenuButtonZones — зоны hit-test; метаданные HMM2MENU.PAK.
  21+ C000              ; Меню переиспользует RAM_G (base 0): adventure-ассеты грузятся позже, в Adventure_Enter.
  22+ C000              ;
  23+ C000              ; Координаты: hit-test в ЛОГИЧЕСКИХ 640×480; DL-вершины — в ФИЗИЧЕСКИХ 1024×768
  24+ C000              ; (×1.6, уже зашито в DL-блоки экстрактором).
  25+ C000              ; ============================================================================
