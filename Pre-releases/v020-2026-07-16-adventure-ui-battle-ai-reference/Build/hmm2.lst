 191  523D                              ; --- Резидентные trampolines к PAK-loader (В SLOT1, #5xxx) ----------
 192  523D                              ; Загрузчик (sd_zc+raw_pak) в overlay-странице HMM2_LOADER_PAGE (slot3).
 193  523D                              ; Trampolines: мапят overlay в slot3, переключают SP на локальный стек
 194  523D                              ; загрузчика (slot1 — raw_pak ремапит slot2 и сломал бы основной стек на
 195  523D                              ; #BFFF), вызывают RawPak_*, восстанавливают Core. ОБЯЗАНЫ быть в slot1:
 196  523D                              ; raw_pak ремапит slot2, и код трамплина в slot2 исчез бы во время вызова
 197  523D                              ; (RET ушёл бы в мусор-страницу буфера — корень «висло до FT812»).
 198  523D              Loader_Init:                                     ; sd_init (byte addressing + dummy clocks)
 199  523D ED 73 78 42                  LD   (LdSavedSP), SP
 200  5241 31 00 43                     LD   SP, LdStackTop
 201  5244 CD 9B 52                     CALL Loader_MapIn
 202  5247 CD 00 C0                     CALL sd_init
 203  524A 18 3E                        JR   Loader_Leave
 204  524C              Loader_Mount:
 205  524C ED 73 78 42                  LD   (LdSavedSP), SP
 206  5250 31 00 43                     LD   SP, LdStackTop
 207  5253 CD 9B 52                     CALL Loader_MapIn
 208  5256 CD 30 C1                     CALL RawPak_Mount
 209  5259 18 2F                        JR   Loader_Leave
 210  525B              Loader_OpenFile:                                 ; HL = имя файла (zero-term)
 211  525B ED 73 78 42                  LD   (LdSavedSP), SP
 212  525F 31 00 43                     LD   SP, LdStackTop
 213  5262 CD 9B 52                     CALL Loader_MapIn
 214  5265 CD 70 C2                     CALL RawPak_OpenFile
 215  5268 18 20                        JR   Loader_Leave
 216  526A              Loader_ReadSectors:                              ; C=dst page, HL=dst off, B=count
 217  526A ED 73 78 42                  LD   (LdSavedSP), SP
 218  526E 31 00 43                     LD   SP, LdStackTop
 219  5271 CD 9B 52                     CALL Loader_MapIn
 220  5274 CD BF C6                     CALL RawPak_ReadSectors
 221  5277 18 11                        JR   Loader_Leave
 222  5279              Loader_SeekSector:                               ; HL = логический сектор файла (RawPak_LogCur)
 223  5279 ED 73 78 42                  LD   (LdSavedSP), SP
 224  527D 31 00 43                     LD   SP, LdStackTop
 225  5280 E5                           PUSH HL
 226  5281 CD 9B 52                     CALL Loader_MapIn
 227  5284 E1                           POP  HL
 228  5285 22 78 CD                     LD   (RawPak_LogCur), HL
 229  5288 18 00                        JR   Loader_Leave
 230  528A              Loader_Leave:                                    ; CF результата raw_pak сохранён
 231  528A F5                           PUSH AF
 232  528B 3E 06                        LD   A, CorePage + 1
 233  528D                              SetPage2_A                       ; raw_pak менял slot2 → вернуть Core
 233  528D             >                ifdef MAPPING_REGISTERS
 233  528D 32 12 04    >                LD (FMADDR_REGS + HIGH PAGE2), A
 233  5290             >                else
 233  5290 ~           >                LD (MemoryPages + 2), A
 233  5290 ~           >                LD BC, PAGE2
 233  5290 ~           >                OUT (C), A
 233  5290             >                endif
 234  5290              Loader_SavedP3 EQU $+1
 235  5290 3E 00                        LD   A, #00
 236  5292                              SetPage3_A
 236  5292             >                ifdef MAPPING_REGISTERS
 236  5292 32 13 04    >                LD (FMADDR_REGS + HIGH PAGE3), A
 236  5295             >                else
 236  5295 ~           >                LD (MemoryPages + 3), A
 236  5295 ~           >                LD BC, PAGE3
 236  5295 ~           >                OUT (C), A
 236  5295             >                endif
 237  5295 F1                           POP  AF
 238  5296 ED 7B 78 42                  LD   SP, (LdSavedSP)             ; вернуть основной стек (slot2 #BFFF)
 239  529A C9                           RET
 240  529B              Loader_MapIn:
 241  529B                              ; SetPage3_A (через A), НЕ SetPage3 (через HL) — Loader_OpenFile передаёт
 242  529B                              ; имя файла в HL, а макрос SetPage3 портит HL (LD HL,FMADDR_REGS...).
 243  529B                              GetPage3
