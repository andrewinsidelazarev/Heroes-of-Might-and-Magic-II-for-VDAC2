 390  53AD             >                else
 390  53AD ~           >                LD (MemoryPages + 2), A
 390  53AD ~           >                LD BC, PAGE2
 390  53AD ~           >                OUT (C), A
 390  53AD             >                endif
 391  53AD 37                           SCF
