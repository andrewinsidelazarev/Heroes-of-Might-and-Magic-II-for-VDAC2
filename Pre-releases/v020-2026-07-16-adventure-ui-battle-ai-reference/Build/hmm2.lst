  86  0000              ; SKIRMISH: игрок Knight (index0, казна KingdomFunds резидент), Sorc = AI (index1, казна здесь в #91).
  87  0000              AI_KINGDOM_OFS       EQU 1 + GSTATE_LEN           ; offset в #91 от GLOBAL_STATE_BASE (после магии+город)
  88  0000              AI_KINGDOM_GOLD_OFS  EQU AI_KINGDOM_OFS           ; Sorc gold 2б
