   1++0000
   2++0000                              ifndef _MEMORY_MACRO_
   3++0000                              define _MEMORY_MACRO_
   4++0000              ; -----------------------------------------
   5++0000              ; initialization of mapping of registers in 0x400-0x4FF
   6++0000              ; if the preprocessing directive MAPPING_REGISTERS is enabled
   7++0000              ; In :
   8++0000              ; Out :
   9++0000              ; Corrupt :
  10++0000              ; Note:
  11++0000              ; -----------------------------------------
  12++0000              FMapAddrInit    macro
  13++0000 ~                            ifdef MAPPING_REGISTERS
  14++0000 ~                            SeFMAddr FM_EN
  15++0000 ~                            endif
  16++0000 ~                            SeMemConfig MEM_WO_RAM | MEM_WO_MAP | MEM_WO_WE
  17++0000 ~                            SetPage0 TSLibPage
  18++0000                              endm
  19++0000              ; -----------------------------------------
  20++0000              ; set values to memory configuration register
  21++0000              ; In :
  22++0000              ;   Value? - memory config values
  23++0000              ; Out :
  24++0000              ; Corrupt :
  25++0000              ;   BC, A
  26++0000              ; Note:
  27++0000              ; -----------------------------------------
  28++0000              SeMemConfig     macro Value?
  29++0000 ~                            LD A, Value?
  30++0000 ~                            LD BC, MEMCONFIG
  31++0000 ~                            OUT (C), A
  32++0000                              endm
  33++0000              ; -----------------------------------------
  34++0000              ; set values in port FMaps Address
  35++0000              ; In :
  36++0000              ;   Value? - config values
  37++0000              ; Out :
  38++0000              ; Corrupt :
  39++0000              ;   BC, A
  40++0000              ; Note:
  41++0000              ; -----------------------------------------
  42++0000              SeFMAddr        macro Value?
  43++0000 ~                            LD A, Value?
  44++0000 ~                            LD BC, FMADDR
  45++0000 ~                            OUT (C), A
  46++0000                              endm
  47++0000              ; -----------------------------------------
  48++0000              ; set the page number from the address #0000 - #3FFF
  49++0000              ; In :
  50++0000              ;   Page? - page number
  51++0000              ; Out :
  52++0000              ; Corrupt :
  53++0000              ;   HL / (BC, A)
  54++0000              ; Note:
  55++0000              ; -----------------------------------------
  56++0000              SetPage0        macro Page?
  57++0000 ~                            ifdef MAPPING_REGISTERS
  58++0000 ~                            LD HL, FMADDR_REGS + HIGH PAGE0
  59++0000 ~                            LD (HL), Page? & 0xFF
  60++0000 ~                            else
  61++0000 ~                            LD A, Page? & 0xFF
  62++0000 ~                            LD (MemoryPages + 0), A
  63++0000 ~                            LD BC, PAGE0
