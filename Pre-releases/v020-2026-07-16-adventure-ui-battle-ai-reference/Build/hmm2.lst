 309  530B ED 5B 2C 53                  LD   DE, (LdStreamRamgLo)
 310  530F 19                           ADD  HL, DE
 311  5310 22 2C 53                     LD   (LdStreamRamgLo), HL
 312  5313 30 07                        JR   NC, .nocy
 313  5315 3A 2E 53                     LD   A, (LdStreamRamgHi)
 314  5318 3C                           INC  A
 315  5319 32 2E 53                     LD   (LdStreamRamgHi), A
 316  531C 2A 2A 53     .nocy:          LD   HL, (LdStreamRemain)        ; remain -= B
 317  531F 7D                           LD   A, L
 318  5320 90                           SUB  B
 319  5321 6F                           LD   L, A
 320  5322 30 01                        JR   NC, .nobor
 321  5324 25                           DEC  H
 322  5325 22 2A 53     .nobor:         LD   (LdStreamRemain), HL
 323  5328 18 98                        JR   .loop
