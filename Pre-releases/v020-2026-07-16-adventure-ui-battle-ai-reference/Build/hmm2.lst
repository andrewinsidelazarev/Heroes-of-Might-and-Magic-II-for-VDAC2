# file opened: Source\ASM\sd_zc.asm
   1+ C000              ;//////////////////////////////////////////////////////////////
   2+ C000              ;//  Самодостаточное чтение raw sector с SD (Z-Controller).
   3+ C000              ;//  Порт из Zuma Deluxe VDAC2 (Source/ASM/sd_zc.asm), то же железо TS-Conf.
   4+ C000              ;//  Карта инициализирована хостом (WC) до старта SPG (hardware state живёт),
   5+ C000              ;//  поэтому здесь отправляются только CMD17 reads.
   6+ C000              ;//  Unreal/этот host использует BYTE addressing (sd_blkt = 0): CMD17 argument
   7+ C000              ;//  равен LBA*512.
   8+ C000              ;//////////////////////////////////////////////////////////////
   9+ C000
  10+ C000              SD_CONF         equ     #77             ; config / chip-select port
  11+ C000              SD_DATA         equ     #57             ; data port
  12+ C000              SD_CMD17        equ     %01000000+17    ; single-block read
