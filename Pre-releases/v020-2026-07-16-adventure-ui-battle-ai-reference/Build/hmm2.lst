 328  532F              ; ----------------------------------------------------------------------------
 329  532F              ; Loader_ApplyPatch — применить ПАТЧ из HMM2TOWN.PAK в RAM_G (строительство по
 330  532F              ; оригиналу: спрайты зданий на панораму / полосы статусов в окно стройки).
 331  532F              ; IN: HL = абсолютный логический сектор патча в файле (PanoPatchSec/BandPatchSec/
 332  532F              ; CornerPatchSec). Формат потока (сектор-локальные записи, см. town_pack._pack_patch):
 333  532F              ;   [len u16][addr u24][len байт]; len=0 → следующий сектор; len=#FFFF → конец.
 334  532F              ; Каждый сектор: Loader_ReadSectors → буфер (slot2) → FT.WriteMem ранов.
 335  532F              ; Живёт в SLOT1 (raw_pak ремапит slot2). CF=1 = ok.
 336  532F              ; ----------------------------------------------------------------------------
 337  532F              Loader_ApplyPatch:
 338  532F 22 B6 53                     LD   (LdPatchSec), HL
 339  5332 21 BD 53                     LD   HL, LdPatchName             ; имя в slot1 (оверлеи в slot2/3 недоступны при ремапе)
 340  5335 CD 5B 52                     CALL Loader_OpenFile             ; CF=1 = ok (Seek0 + run-table)
 341  5338 D0                           RET  NC
 342  5339 2A B6 53                     LD   HL, (LdPatchSec)
 343  533C CD 79 52                     CALL Loader_SeekSector           ; LogCur = сектор патча
 344  533F 0E A1        .sector:        LD   C, RAWPAK_BUF_PAGE          ; сектор потока → буфер-страница
 345  5341 21 00 00                     LD   HL, 0
 346  5344 06 01                        LD   B, 1
 347  5346 CD 6A 52                     CALL Loader_ReadSectors          ; CF=1 = ОШИБКА (конвенция RawPak_ReadSectors)
 348  5349 38 64                        JR   C, .fail
 349  534B 3E A1                        LD   A, RAWPAK_BUF_PAGE
 350  534D                              SetPage2_A                       ; буфер в окно slot2 для FT.WriteMem
 350  534D             >                ifdef MAPPING_REGISTERS
 350  534D 32 12 04    >                LD (FMADDR_REGS + HIGH PAGE2), A
 350  5350             >                else
 350  5350 ~           >                LD (MemoryPages + 2), A
 350  5350 ~           >                LD BC, PAGE2
 350  5350 ~           >                OUT (C), A
 350  5350             >                endif
 351  5350 DD 21 00 80                  LD   IX, #8000                   ; курсор потока в секторе
 352  5354 DD 5E 00     .rec:           LD   E, (IX+0)
 353  5357 DD 56 01                     LD   D, (IX+1)                   ; DE = len записи
 354  535A 7A                           LD   A, D
 355  535B A3                           AND  E
 356  535C 3C                           INC  A
 357  535D 28 49                        JR   Z, .done                    ; len = #FFFF → конец патча
 358  535F 7A                           LD   A, D
 359  5360 B3                           OR   E
 360  5361 28 3E                        JR   Z, .next_sector             ; len = 0 → следующий сектор
 361  5363 ED 53 B8 53                  LD   (LdPatchLen), DE
 362  5367 DD 6E 02                     LD   L, (IX+2)
 363  536A DD 66 03                     LD   H, (IX+3)
 364  536D 22 BA 53                     LD   (LdPatchLo), HL             ; RAM_G адрес lo16
 365  5370 DD 7E 04                     LD   A, (IX+4)
 366  5373 32 BC 53                     LD   (LdPatchHi), A              ; RAM_G адрес hi
 367  5376 DD E5                        PUSH IX
 368  5378 E1                           POP  HL
 369  5379 11 05 00                     LD   DE, 5
 370  537C 19                           ADD  HL, DE                      ; HL = данные рана (в буфере slot2)
 371  537D 3A BC 53                     LD   A, (LdPatchHi)
 372  5380 ED 5B BA 53                  LD   DE, (LdPatchLo)
 373  5384 ED 4B B8 53                  LD   BC, (LdPatchLen)
 374  5388 CD 23 7C                     CALL FT.WriteMem                 ; ран → RAM_G
 375  538B 3E A1                        LD   A, RAWPAK_BUF_PAGE          ; WriteMem мог вернуть Core в slot2 — буфер обратно
 376  538D                              SetPage2_A
 376  538D             >                ifdef MAPPING_REGISTERS
 376  538D 32 12 04    >                LD (FMADDR_REGS + HIGH PAGE2), A
 376  5390             >                else
 376  5390 ~           >                LD (MemoryPages + 2), A
 376  5390 ~           >                LD BC, PAGE2
 376  5390 ~           >                OUT (C), A
 376  5390             >                endif
 377  5390 DD E5                        PUSH IX
 378  5392 E1                           POP  HL
 379  5393 ED 5B B8 53                  LD   DE, (LdPatchLen)
 380  5397 19                           ADD  HL, DE
 381  5398 11 05 00                     LD   DE, 5
 382  539B 19                           ADD  HL, DE                      ; IX += 5 + len
 383  539C E5                           PUSH HL
 384  539D DD E1                        POP  IX
 385  539F 18 B3                        JR   .rec
 386  53A1 3E 06        .next_sector:   LD   A, CorePage + 1
 387  53A3                              SetPage2_A                       ; вернуть Core перед raw_pak (он ремапит сам)
 387  53A3             >                ifdef MAPPING_REGISTERS
 387  53A3 32 12 04    >                LD (FMADDR_REGS + HIGH PAGE2), A
 387  53A6             >                else
 387  53A6 ~           >                LD (MemoryPages + 2), A
 387  53A6 ~           >                LD BC, PAGE2
 387  53A6 ~           >                OUT (C), A
 387  53A6             >                endif
 388  53A6 18 97                        JR   .sector
 389  53A8 3E 06        .done:          LD   A, CorePage + 1
 390  53AA                              SetPage2_A                       ; вернуть Core в slot2
 390  53AA             >                ifdef MAPPING_REGISTERS
