 351+ 0020              ; Note:
 352+ 0020              ; -----------------------------------------
 353+ 0020              ; select video resolution
 354+ 0020              FT_RESOLUTION   macro Resolution?, ResolutionRef?
 355+ 0020 ~                            if     Resolution? == VM_640_480_57Hz
 356+ 0020 ~                            LD HL, 640
 357+ 0020 ~                            LD (ResolutionRef? + 0), HL
 358+ 0020 ~                            LD HL, 480
 359+ 0020 ~                            LD (ResolutionRef? + 2), HL
 360+ 0020 ~                            elseif Resolution? == VM_640_480_74Hz
 361+ 0020 ~                            LD HL, 640
 362+ 0020 ~                            LD (ResolutionRef? + 0), HL
 363+ 0020 ~                            LD HL, 480
 364+ 0020 ~                            LD (ResolutionRef? + 2), HL
 365+ 0020 ~                            elseif Resolution? == VM_640_480_76Hz
 366+ 0020 ~                            LD HL, 640
 367+ 0020 ~                            LD (ResolutionRef? + 0), HL
 368+ 0020 ~                            LD HL, 480
 369+ 0020 ~                            LD (ResolutionRef? + 2), HL
 370+ 0020 ~                            elseif Resolution? == VM_800_600_60Hz
 371+ 0020 ~                            LD HL, 800
 372+ 0020 ~                            LD (ResolutionRef? + 0), HL
 373+ 0020 ~                            LD HL, 600
 374+ 0020 ~                            LD (ResolutionRef? + 2), HL
 375+ 0020 ~                            elseif Resolution? == VM_800_600_69Hz
 376+ 0020 ~                            LD HL, 800
 377+ 0020 ~                            LD (ResolutionRef? + 0), HL
 378+ 0020 ~                            LD HL, 600
 379+ 0020 ~                            LD (ResolutionRef? + 2), HL
 380+ 0020 ~                            elseif Resolution? == VM_800_600_85Hz
 381+ 0020 ~                            LD HL, 800
 382+ 0020 ~                            LD (ResolutionRef? + 0), HL
 383+ 0020 ~                            LD HL, 600
 384+ 0020 ~                            LD (ResolutionRef? + 2), HL
 385+ 0020 ~                            elseif Resolution? == VM_1024_768_59Hz
 386+ 0020 ~                            LD HL, 1024
 387+ 0020 ~                            LD (ResolutionRef? + 0), HL
 388+ 0020 ~                            LD HL, 768
 389+ 0020 ~                            LD (ResolutionRef? + 2), HL
 390+ 0020 ~                            elseif Resolution? == VM_1024_768_67Hz
 391+ 0020 ~                            LD HL, 1024
 392+ 0020 ~                            LD (ResolutionRef? + 0), HL
 393+ 0020 ~                            LD HL, 768
 394+ 0020 ~                            LD (ResolutionRef? + 2), HL
 395+ 0020 ~                            elseif Resolution? == VM_1024_768_76Hz
 396+ 0020 ~                            LD HL, 1024
 397+ 0020 ~                            LD (ResolutionRef? + 0), HL
 398+ 0020 ~                            LD HL, 768
 399+ 0020 ~                            LD (ResolutionRef? + 2), HL
 400+ 0020 ~                            endif
 401+ 0020 ~                            LD HL, Resolution?
 402+ 0020 ~                            CALL FT.Initialize
 403+ 0020                              endm
 404+ 0020              ; -----------------------------------------
 405+ 0020              ; write a data to memory area of 'Display List' FT812
 406+ 0020              ; In :
 407+ 0020              ;   Address? - lower 16 bits of the FT_RAM_DL address
 408+ 0020              ;   Offset?  - 16-bit destination offset from RAM_DL FT812
 409+ 0020              ;   Size?    - number of bytes to copy
 410+ 0020              ; Out :
 411+ 0020              ; Corrupt :
 412+ 0020              ;   HL, BC, AF
 413+ 0020              ; Note:
 414+ 0020              ; -----------------------------------------
 415+ 0020              FT_WR_DL        macro Source?, Offset?, Size?
 416+ 0020 ~                            LD HL, Source? & 0xFFFF
 417+ 0020 ~                            LD A, (FT_RAM_DL >> 16) & 0xFF
 418+ 0020 ~                            LD DE, Offset? & FT_DL_MASK
 419+ 0020 ~                            LD BC, Size? & FT_DL_MASK
 420+ 0020 ~                            CALL FT.WriteMem
 421+ 0020                              endm
 422+ 0020              ; -----------------------------------------
 423+ 0020              ; write a data to the FIFO command i.e. RAM_CMD
 424+ 0020              ; In :
 425+ 0020              ;   Address? - lower 16 bits of the FT_RAM_DL address
 426+ 0020              ;   Size?    - number of bytes to copy
 427+ 0020              ;   if the C flag is set, it is necessary to align the data with 4 bytes
 428+ 0020              ; Out :
 429+ 0020              ; Corrupt :
 430+ 0020              ;   HL, BC, AF
 431+ 0020              ; Note:
 432+ 0020              ; -----------------------------------------
 433+ 0020              FT_WR_CMD       macro Address?, Size?
 434+ 0020 ~                            LD HL, Address? & 0xFFFF
 435+ 0020 ~                            LD BC, Size? & 0xFFFF
 436+ 0020 ~                            CALL FT.Coprocessor.Write
 437+ 0020                              endm
 438+ 0020              ; -----------------------------------------
 439+ 0020              ; write a 32-bits value to the FIFO command i.e. RAM_CMD
 440+ 0020              ; In :
 441+ 0020              ;   Value? - 32-bits value
 442+ 0020              ; Out :
 443+ 0020              ;   if the C flag is set, the coprocessor is fault,
 444+ 0020              ;   otherwise the command or data has successfully append to FIFO
 445+ 0020              ; Corrupt :
 446+ 0020              ;   HL, DE, F
 447+ 0020              ; Note:
 448+ 0020              ; -----------------------------------------
 449+ 0020              FT_WR32_CMD     macro Value?
 450+ 0020 ~                            LD HL, (Value? >> 16) & 0xFFFF
 451+ 0020 ~                            LD DE, Value? & 0xFFFF
 452+ 0020 ~                            CALL FT.Coprocessor.Write32
 453+ 0020                              endm
 454+ 0020              ; -----------------------------------------
 455+ 0020              ; write a data to memory FT812 by DMA
 456+ 0020              ; In :
 457+ 0020              ;   Source?      - source address (0x0000 - 0x3FFF)
 458+ 0020              ;   SourcePage?  - source number page
 459+ 0020              ;   Destination? - 22-bit destination address FT
 460+ 0020              ;   Size?        - number of bytes to copy
 461+ 0020              ; Out :
 462+ 0020              ; Corrupt :
 463+ 0020              ;  HL, DE, BC, AF
 464+ 0020              ; Note:
 465+ 0020              ; -----------------------------------------
 466+ 0020              FT_WR_DMA       macro Source?, SourcePage?, Destination?, Size?
 467+ 0020 ~                            FT_ON
 468+ 0020 ~
 469+ 0020 ~                            ; for SPI memory write transactions, the host sends a ‘1’ bit and ‘0’ bit, followed by the 22-bit address. This is followed by the write data.
 470+ 0020 ~                            LD A, (Destination? >> 16) & 0xFF
 471+ 0020 ~                            OR #80
 472+ 0020 ~                            OUT (SPI_DATA), A
 473+ 0020 ~                            LD A, (Destination? >> 8) & 0xFF
 474+ 0020 ~                            OUT (SPI_DATA), A
 475+ 0020 ~                            LD A, (Destination? >> 0) & 0xFF
 476+ 0020 ~                            OUT (SPI_DATA), A
 477+ 0020 ~
 478+ 0020 ~                            ; set source address DMA (RAM)
 479+ 0020 ~                            DMA_Src SourcePage? & 0xFF, Source? & 0x3FFF
 480+ 0020 ~
 481+ 0020 ~                            ; DEBC = data length in bytes
 482+ 0020 ~                            LD DE, (Size? >> 17) & 0x0007
 483+ 0020 ~                            LD BC, (Size? >> 1)  & 0xFFFF
 484+ 0020 ~
 485+ 0020 ~                            ;
 486+ 0020 ~                            PUSH BC
 487+ 0020 ~
 488+ 0020 ~                            ;
 489+ 0020 ~                            LD A, E
 490+ 0020 ~                            OR A
 491+ 0020 ~                            JR Z, .Less_128kb
 492+ 0020 ~
 493+ 0020 ~            .Send128kb      DMA_Size 256, 512
 494+ 0020 ~                            DMA_Ctrl DMA_RAM_SPI
 495+ 0020 ~                            DMA_Wait
 496+ 0020 ~                            DEC E
 497+ 0020 ~                            JR NZ, .Send128kb
 498+ 0020 ~
 499+ 0020 ~            .Less_128kb     POP BC
 500+ 0020 ~                            LD A, C
 501+ 0020 ~                            EX AF, AF'
 502+ 0020 ~
 503+ 0020 ~                            ;
 504+ 0020 ~                            LD A, B
 505+ 0020 ~                            OR A
 506+ 0020 ~                            JR Z, .Less512b
 507+ 0020 ~
 508+ 0020 ~                            ;
 509+ 0020 ~                            LD BC, DMANUM
 510+ 0020 ~                            OUT (C), A
 511+ 0020 ~                            LD B, HIGH DMALEN
 512+ 0020 ~                            LD A, #FF
 513+ 0020 ~                            OUT (C), A
 514+ 0020 ~                            DMA_Ctrl DMA_RAM_SPI
 515+ 0020 ~                            DMA_Wait
 516+ 0020 ~
 517+ 0020 ~            .Less512b       EX AF, AF'
 518+ 0020 ~                            OR A
 519+ 0020 ~                            JR Z, .End
 520+ 0020 ~                            EX AF, AF'
 521+ 0020 ~                            XOR A
 522+ 0020 ~                            LD BC, DMANUM
 523+ 0020 ~                            OUT (C), A
 524+ 0020 ~                            LD B, HIGH DMALEN
 525+ 0020 ~                            EX AF, AF'
 526+ 0020 ~                            OUT (C), A
 527+ 0020 ~                            DMA_Ctrl DMA_RAM_SPI
 528+ 0020 ~                            DMA_Wait
 529+ 0020 ~
 530+ 0020 ~            .End            FT_OFF
 531+ 0020                              endm
 532+ 0020
 533+ 0020                              endif ; ~_FT812_MACRO_
