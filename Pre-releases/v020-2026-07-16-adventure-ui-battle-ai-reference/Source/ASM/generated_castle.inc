; Сгенерировано Source/Tools/dump_mp2_castles.py — РЕАЛЬНЫЕ данные замка игрока из MX2.
                ifndef _HMM2_GENERATED_CASTLE_
                define _HMM2_GENERATED_CASTLE_

CastleName:      DEFB "Hampshire", 0        ; имя замка игрока (MP2 custom name)
CASTLE_NAME_LEN  EQU 9
CASTLE_RACE      EQU 0          ; 0=KNGT
CASTLE_IS_CASTLE EQU 1
CASTLE_POS_X     EQU 24
CASTLE_POS_Y     EQU 13
CASTLE_HAS_CAPTAIN EQU 0
CASTLE_MAGEGUILD EQU 0
CASTLE_CUSTOM_BLD EQU 0   ; 0 = дефолтные постройки (_setDefaultBuildings)
CASTLE_COMMON_BITS EQU #0000
CASTLE_DWELL_BITS  EQU #0000
                endif